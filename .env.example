# Local development only (python wsgi.py).
# Docker Compose ignores this file — it has its own hardcoded container values.

SECRET_KEY=dev-change-me-in-production

# On Linux: /usr/games/stockfish
# On macOS (Homebrew): /opt/homebrew/bin/stockfish
STOCKFISH_PATH=/usr/games/stockfish

# Optional — leave unset for SQLite in ./data/chess.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/chess

# Optional — only needed for SocketIO message queue if running multiple replicas
# REDIS_URL=redis://localhost:6379/0
